DOCKER_BINARY=docker
DB_HOSTNAME=db
DB_IMAGE=mariadb:10.11
LOCAL_USER_ID=1000
SYNC_REPO=C:/Users/kosson/Documents/DEVELOPMENT/koha-docker-windows/koha
EDITOR=vim
ENABLE_IPV4=true
ENABLE_IPV6=false
GIT_BZ_PASSWORD=cevaDeP0M11n4
GIT_BZ_USER=kosson@gmail.com
GIT_USER_EMAIL=kosson@gmail.com
GIT_USER_NAME="Nicolaie Constantinescu"
DEBUG_GIT_REPO_MISC4DEV=no
DEBUG_GIT_REPO_MISC4DEV_URL=https://gitlab.com/koha-community/koha-misc4dev.git
DEBUG_GIT_REPO_MISC4DEV_BRANCH=main
DEBUG_GIT_REPO_QATESTTOOLS=no
DEBUG_GIT_REPO_QATESTTOOLS_URL=https://gitlab.com/koha-community/qa-test-tools.git
DEBUG_GIT_REPO_QATESTTOOLS_BRANCH=main
DEBUG_RUN=no
DEBUG_RUN_URL=https://gitlab.com/joubu/koha-testing-docker/-/raw/test/files/run.sh
KOHA_IMAGE=main
KOHA_CONF=/etc/koha/sites/kohadev/koha-conf.xml
KOHA_DB_PASSWORD=password
KOHA_DOMAIN=.127.0.0.1.nip.io
KOHA_INSTANCE=kohadev
KOHA_INTRANET_PORT=8081
KOHA_INTRANET_PREFIX=
KOHA_INTRANET_SUFFIX=-intra
KOHA_MARC_FLAVOUR=marc21
KOHA_OPAC_PORT=8080
KOHA_OPAC_PREFIX=
KOHA_OPAC_SUFFIX=
# KOHA_PUBLIC_PORT: public-facing HTTP port served by Traefik (matches TRAEFIK_HTTP_PORT
# in traefik/.env).  URLs stored in the Koha database (OPACBaseURL, staffClientBaseURL)
# will use this port.  Port 80 is the default for HTTP, so it is omitted from URLs —
# meaning links in Koha pages will NOT contain ":8080".
# Change to match TRAEFIK_HTTP_PORT if you run Traefik on a non-standard port (e.g. 8000).
KOHA_PUBLIC_PORT=80
KOHA_PASS=koha
KOHA_PROVE_CPUS=
KOHA_USER=koha
MANA_URL=https://mana-test.koha-community.org
PERL5LIB=/kohadevbox/koha:/kohadevbox/koha/lib:/kohadevbox/qa-test-tools
REMOTE_DEBUGGER_KEY=
REMOTE_DEBUGGER_LOCATION=host.docker.internal:9000
SELENIUM_ADDR=selenium
SELENIUM_PORT=4444
KOHA_ELASTICSEARCH=yes
PLACK_MAX_REQUESTS=50
PLACK_WORKERS=2
# ELASTIC_SERVER: URL of the OpenSearch cluster manager node (NO credentials in URL).
# Credentials go via ELASTIC_OPTIONS as <userinfo>user:pass</userinfo> so Search::Elasticsearch
# base64-encodes the raw password, not the URL-encoded form.
# <ssl_options><SSL_verify_mode>0</SSL_verify_mode></ssl_options> disables TLS cert verification.
# <client_version>7</client_version> bypasses the Elasticsearch 8.x product check that
# rejects OpenSearch (which returns x-elastic-product: OpenSearch, not Elasticsearch).
ELASTIC_SERVER=https://os01:9200
ELASTIC_OPTIONS=<ssl_options><SSL_verify_mode>0</SSL_verify_mode></ssl_options><userinfo>admin:test@Cici24#ANA</userinfo><client_version>7</client_version>
PERL_LWP_SSL_VERIFY_HOSTNAME=0
# Path on the HOST to the OpenSearch root CA certificate (mounted into /kohadevbox/opensearch-root-ca.pem).
# Uncomment and set to enable proper TLS verification instead of bypassing it.
OPENSEARCH_CA_CERT=C:/Users/kosson/Documents/DEVELOPMENT/koha-docker-windows/OpenSearch-3.6/assets/ssl/root-ca.pem
OPENSEARCH_INITIAL_ADMIN_PASSWORD="test@Cici24#ANA"
CI_RUN=no
CPAN=no
INSTALL_MISSING_FROM_CPANFILE=no
KEYCLOAK_ADMIN=keycloak
KEYCLOAK_ADMIN_PASS=keycloak
KEYCLOAK_REALM=koha
USE_EXISTING_DB=
# LOAD_DEMO_DATA: 'yes' (default) — loads sample MARC bibliographic records,
# authority records, items, and patron data via misc4dev/insert_data.pl.
# Set to 'no' for a clean Koha install (superlibrarian account only, empty catalogue).
# Controlled by './stack.sh start --with-demo-data' / '--no-demo-data'.
LOAD_DEMO_DATA=yes
SKIP_L10N=
EXTRA_CPAN=
EXTRA_APT=
ENABLE_SMTP=
SMTP_IMAGE=
